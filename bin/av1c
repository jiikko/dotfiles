#!/usr/bin/env zsh
# @DotfilesSyncer: finder-menu true
# @DotfilesSyncer:accepts .mp4,.mov,.mkv,.avi,.wmv,.rm,.mpg,.mpeg,.flv,.webm,.3gp,.ts
# @DotfilesSyncer:input-type file,files,directory
# @DotfilesSyncer:description av1c（720p+30fps）で変換
# @DotfilesSyncer:submenu resolution --resolution:720p,1080p
#
# av1c — av1ify --compact のショートハンド（720p + 30fps プリセット）
#
# ⚠️ 単なる --compact ではない: --delete-origin-if-success-and-no-ng を併用するため、
# 変換成功 + postcheck NG なしの場合に元ファイルをゴミ箱へ移動する。
# 元ファイルを残したい場合は bin/av1ify (または av1ify -c) を使うこと。
#
# 実装: ~/dotfiles/zshlib/_av1ify.zsh
#
# 関連:
#   - ~/dotfiles/bin/av1ify  フルオプション版 (元ファイルは残す)

source "${0:A:h}/../zshlib/_av1ify.zsh"
av1ify --compact --delete-origin-if-success-and-no-ng "$@"
