#!/usr/bin/env zsh
# git-popup — tmux の git 操作 popup を担う Go TUI。log 一覧 (行頭に CI job の成否マークを
# 非同期表示) と changes/staging (stage/commit/push) を C-l でトグルする単一 TUI。
# Go 実装は ~/dotfiles/src/git-popup/。glog は read-only ツールとして別物 (本ツールは触らない)。
# このラッパーは初回にバイナリを自動ビルドし、ソースが新しいと再ビルドする (bin/glog と同方式)。

set -u

src_dir="${0:A:h}/../src/git-popup"
bin="$src_dir/git-popup"

needs_build=0
if [[ ! -x "$bin" ]]; then
  needs_build=1
else
  # Rebuild if any .go source is newer than the binary.
  for f in "$src_dir"/*.go "$src_dir"/go.mod "$src_dir"/go.sum; do
    [[ -e "$f" ]] || continue
    if [[ "$f" -nt "$bin" ]]; then
      needs_build=1
      break
    fi
  done
fi

if (( needs_build )); then
  echo "git-popup: building..." >&2
  (cd "$src_dir" && go build -o git-popup .) || {
    echo "git-popup: build failed" >&2
    exit 1
  }
fi

exec "$bin" "$@"
