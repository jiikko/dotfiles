#!/usr/bin/env zsh
# glogx — glog (read-only) に push 機能 (C-b) を足した派生版。Go implementation at:
#   ~/dotfiles/src/glogx/
# This wrapper auto-builds the binary on first use and re-builds when the
# source is newer than the compiled artifact.

set -u

src_dir="${0:A:h}/../src/glogx"
bin="$src_dir/glogx"

needs_build=0
if [[ ! -x "$bin" ]]; then
  needs_build=1
else
  # Rebuild if any .go source is newer than the binary. サブパッケージ (usage/ 等) も
  # 含めて再帰的に走査する: トップレベル *.go だけだと usage/*.go の変更で再ビルドされず
  # 古いバイナリが残る (**/*.go は zsh 再帰 glob でトップレベルも含む。(N)=nullglob)。
  for f in "$src_dir"/**/*.go(N) "$src_dir"/go.mod "$src_dir"/go.sum; do
    [[ -e "$f" ]] || continue
    # *_test.go は go build の入力にならない (生成物は同一) ので再ビルドのトリガから除外し、
    # テスト編集ループ中の無駄なビルド待ちを避ける。**/*.go~*_test.go は zsh の * が / を
    # 跨がず usage/*_test.go を取りこぼすため、ループ内で弾く。
    [[ "$f" == *_test.go ]] && continue
    if [[ "$f" -nt "$bin" ]]; then
      needs_build=1
      break
    fi
  done
fi

if (( needs_build )); then
  echo "glogx: building..." >&2
  (cd "$src_dir" && go build -o glogx .) || {
    echo "glogx: build failed" >&2
    exit 1
  }
fi

exec "$bin" "$@"
