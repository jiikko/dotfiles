# NOTE: benchmark disk write speed
bdr() {
  if [[ -z "$1" ]]; then
    echo "Usage: bdr <output_file>"
    return 1
  fi

  local output_file="$1"
  local bs="1m"
  local count="10000"
  local oflag="direct"

  echo "Writing zeros to $output_file..."
  dd if=/dev/zero of="$output_file" bs="$bs" count="$count" oflag="$oflag" status=progress
}

# 動画系コマンドの lazy-reload ラッパー: 呼び出しごとに lib を source し直し、シェル再起動なしで
# lib の編集を反映する。lib は公開名と同名の関数を再定義してこのラッパー自身を上書きするため、
# 実行後に save/restore で復元が必須 (t/tt は公開名≠実体名で復元不要な別 idiom。ここに統合しないこと)。
# 引数: $1=公開関数名 $2=lib パス $3=lib 内の実体関数名 (以降が実引数)
_reload_then_call() {
  local _fname="$1" _lib="$2" _impl="$3"
  shift 3
  local _saved="${functions[$_fname]}"
  source "$_lib"
  "$_impl" "$@"
  local _ret=$?
  functions[$_fname]="$_saved"
  return $_ret
}
av1ify()       { _reload_then_call av1ify       "$HOME/dotfiles/zshlib/_av1ify.zsh"       av1ify       "$@" }
concat()       { _reload_then_call concat       "$HOME/dotfiles/zshlib/_concat.zsh"       concat       "$@" }
repair()       { _reload_then_call repair       "$HOME/dotfiles/zshlib/_repair.zsh"       repair       "$@" }
# repair_mp4 は _repair.zsh 経由で定義される直接呼び出し可能なコマンド (旧 eager source で
# シェル起動時から使えていた互換を維持する)
repair_mp4()   { _reload_then_call repair_mp4   "$HOME/dotfiles/zshlib/_repair.zsh"       repair_mp4   "$@" }
# validate-mp4 の実体は validate_mp4() (対話シェルではハイフン名でも呼べるようにする)
validate-mp4() { _reload_then_call validate-mp4 "$HOME/dotfiles/zshlib/_validate_mp4.zsh" validate_mp4 "$@" }

function rrr() {
  local inputfile="$1"
  if [[ ! -f "$inputfile" ]]; then
    echo "Error: File not found - $inputfile" >&2
    return 1
  fi
  local dir="${inputfile:h}"
  local basename="${inputfile:t}"
  local tmpfile="${dir}/.${basename}.mp4.tmp"

  if ffmpeg -i "$inputfile" -c copy -tag:v hvc1 -movflags +faststart -f mp4 "$tmpfile"; then
    mv "$tmpfile" "$inputfile"
    echo "Repacked and replaced: $inputfile"
  else
    echo "Error: ffmpeg failed for $inputfile" >&2
    rm -f "$tmpfile"
    return 1
  fi
}

