# origin のデフォルトブランチを pull する。判定は git remote show origin (毎回通信が必要で遅く、オフラインでは失敗) を避け、
# ローカルの origin/HEAD 参照で行う。未設定なら一度だけ set-head --auto で問い合わせて設定し、以後はローカルで解決する。
function gm() {
  local branch
  branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
  if [[ -z "$branch" ]]; then
    git remote set-head origin --auto >/dev/null 2>&1
    branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
  fi
  branch=${branch#origin/}
  if [[ "$branch" == "master" || "$branch" == "main" ]]; then
    git pull origin "$branch"
  else
    echo "Error: Default branch is neither master nor main (got: ${branch:-unknown})"
    return 1
  fi
}

