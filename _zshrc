function commit_id_url() {
  HOST_AND_PATH=$(git remote -v | grep origin | head -n 1 | tr ':' '/' | sed -e 's|.*@\(github.com/[^.]*\)\..*$|\1|')
  HEAD_COMMMIT_ID=$(git rev-parse HEAD)
  echo https://${HOST_AND_PATH}/commit/${HEAD_COMMMIT_ID}
}

function git_file_url() {
